{
    "author": "Raman Lauryniuk <romanrostislavovich@gmail.com>",
    "name": "translate-lint",
    "version": "1.2.0",
    "description": "Simple tools for checking translate keys in the whole app that uses regexp. Support for popular libraries and frameworks\n",
    "license": "MIT",
    "repository": "https://github.com/romanrostislavovich/translate-lint.git",
    "bugs": "https://github.com/romanrostislavovich/translate-lint/issues",
    "bin": {
        "translate-lint": "./dist/bin.js"
    },
    "main": "./dist/src/core/index.js",
    "scripts": {
        "tsc": "./node_modules/.bin/tsc",
        "markdownlint": "./node_modules/.bin/markdownlint",
        "tslint": "./node_modules/.bin/tslint",
        "doc:cli": "typedoc --mode modules --excludePrivate --excludeProtected --out ./docs/cli/ ./src/cli/",
        "doc:core": "typedoc --mode modules --excludePrivate --excludeProtected --out ./docs/core/ ./src/core/",
        "doc": "npm run doc:core && npm run doc:cli",
        "lint:typescript": "tslint -c tslint.json --project . -t codeFrame",
        "lint:markdown": "markdownlint --config ./config/markdownlint.json ./docs/**/*.md",
        "test:unit": "nyc mocha -r ts-node/register './test/unit/**/*.test.ts'",
        "test:regexp": "nyc mocha -r ts-node/register './test/regexp/**/*.test.ts'",
        "test:all": "nyc mocha -r ts-node/register './test/unit/**/*.test.ts' './test/regexp/**/*.test.ts' './test/integration/**/*.test.ts'",
        "test:integration": "mocha -r ts-node/register './test/integration/**/*.test.ts'",
        "test:url": "npm run build && node dist/bin.js -p \"test/integration/angular-ngx-translate/inputs/views/*.html\" -l \"https://raw.githubusercontent.com/romanrostislavovich/translate-lint/refs/heads/master/test/integration/angular-ngx-translate/inputs/locales/EN-eu.json\" --kv disable",
        "build": "tsc -p . && gulp -f ./config/gulp.js",
        "lint": "npm run lint:typescript && npm run lint:markdown",
        "test": "npm run test:all && npm run test:url",
        "pre:release": "npm run lint && npm run build && npm run test",
        "semantic-release": "env-cmd semantic-release --no-ci",
        "packed": "translate-lint  -c test/integration/angular-ngx-translate/config/custom.config.json",
        "self-lint": "npx translate-lint -p test/integration/angular-ngx-translate/inputs/views/*.{html,ts} -l ./test/integration/angular-ngx-translate/inputs/locales/*.json -i ./test/integration/angular-ngx-translate/inputs/locales/incorrect.json"
    },
    "files": [
        "dist/",
        "README.md"
    ],
    "keywords": [
        "ngx-translate",
        "translate-lint",
        "validator",
        "linting",
        "cli"
    ],
    "publishConfig": {
        "registry": "https://registry.npmjs.org/",
        "tag": "latest",
        "access": "public"
    },
    "nyc": {
        "check-coverage": true,
        "lines": 70,
        "statements": 70,
        "functions": 70,
        "branches": 70,
        "extension": [
            ".ts",
            ".tsx"
        ],
        "exclude": [
            "coverage/**/*",
            "test/**/*",
            "dist/**/*",
            "src/config.ts",
            "index.ts",
            "bin.ts",
            "src/cli/**/*",
            "config/**/*"
        ],
        "reporter": [
            "html",
            "text-summary"
        ],
        "all": true,
        "require": [
            "ts-node/register"
        ]
    },
    "dependencies": {
        "chalk": "4.1.2",
        "commander": "^14.0.1",
        "conventional-cli": "^1.2.0",
        "dir-glob": "^3.0.1",
        "glob": "^11.0.3",
        "js-yaml": "^4.2.0",
        "lodash": "^4.17.21",
        "string-similarity": "^4.0.4"
    },
    "devDependencies": {
        "@types/chai": "^5.2.2",
        "@types/dir-glob": "^2.0.3",
        "@types/js-yaml": "^4.0.9",
        "@types/lodash": "^4.17.20",
        "@types/mocha": "^10.0.10",
        "@types/sinon": "^21.0.1",
        "@types/string-similarity": "^4.0.2",
        "chai": "^4.2.0",
        "gulp": "^5.0.1",
        "gulp-copy": "^5.0.0",
        "husky": "^2.3.0",
        "markdownlint-cli": "^0.45.0",
        "mocha": "^11.7.4",
        "nyc": "^17.1.0",
        "sinon": "^7.5.0",
        "ts-node": "^10.6.0",
        "tslint": "^5.11.0",
        "typedoc": "^0.28.13",
        "typescript": "^5.9.3"
    }
}
